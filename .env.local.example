# Public app configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TEMPO_RPC=https://rpc.moderato.tempo.xyz
NEXT_PUBLIC_TEMPO_CHAIN_ID=42431
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_PAYROLL_TREASURY=0x93dfCcd80895147EfC1c191013cD935f18a79859
NEXT_PUBLIC_PAYROLL_BATCHER=0x58E5102BAED1c703dC1052cc7f5E30A96af34Eb8
NEXT_PUBLIC_EMPLOYEE_REGISTRY=0x1fF7E623CFdb6e263Be0D25A9142DD7888F5CBdA
NEXT_PUBLIC_STREAM_VESTING=0x71a2BA383d2C8ec15310705A13693F054271531f
NEXT_PUBLIC_YIELD_ROUTER=0x41dD786b2e01825437e2F67b51719CBeDcd527b0
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server-only app configuration
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
BRIDGE_API_KEY=your_bridge_api_key
BRIDGE_WEBHOOK_SECRET=your_bridge_webhook_secret
TEMPO_WEBHOOK_SECRET=your_tempo_webhook_secret
# MPP fee recipient. MUST be an EOA (no contract code) — used as `recipient`
# on Tempo mainnet (chainId 4217), so picking a contract that doesn't exist
# on mainnet will permanently strand fees. Easiest: reuse the REMLO_AGENT
# public address (you already hold its key).
REMLO_TREASURY_ADDRESS=0xYourFeeTreasuryWallet

# x402 Solana fee recipient. MUST be a Solana EOA holding (or able to hold)
# an SPL-USDC token account on the active cluster (devnet vs mainnet-beta
# determined by NEXT_PUBLIC_SOLANA_CLUSTER). Easiest: reuse the
# PRIVY_SOLANA_AGENT_WALLET_ADDRESS — same wallet we already use for Solana
# agent ops. The token account is auto-created by Bridge/x402 facilitators
# on first incoming payment if missing.
SOLANA_FEE_RECIPIENT_ADDRESS=BxoTaz3cbrVafhA2chLWAPNzdV5JAvh1YTHJbgD79kn7

# x402 Base fee recipient. EVM EOA on Base mainnet (chainId 8453). Receives
# USDC at 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913. CDP facilitator handles
# verify + settle. Reuse REMLO_AGENT public address since the same EOA can
# hold balance on every EVM chain.
BASE_FEE_RECIPIENT_ADDRESS=0xC9231C08460F63794F0bd9C6AF6D2b6D76aCEDb5
REMLO_AGENT_PRIVATE_KEY=0xYourServerAgentPrivateKey
RESEND_API_KEY=your_resend_api_key
# Signing secret from Resend dashboard → Webhooks. Used to verify delivery
# event payloads at /api/webhooks/resend. Optional in dev (skipped with
# warning); REQUIRED in prod or anyone can spoof bounce events.
RESEND_WEBHOOK_SECRET=whsec_your_resend_signing_secret
CLAUDE_API_KEY=your_anthropic_api_key
STRIPE_SECRET_KEY=your_stripe_secret_key
MPP_SECRET_KEY=your_mpp_secret_key
ADMIN_USER_IDS=

# Local-only demo helpers
DEMO_MPP_CREDENTIAL=
DEMO_EMPLOYER_ID=
DEMO_PAYROLL_RUN_ID=

# Contract deployment only
DEPLOYER_PRIVATE_KEY=0xYourTempoDeploymentPrivateKey

# Privy server wallets (all agent-initiated signing as of Ship 1)
# Populate via: pnpm tsx scripts/setup-privy-server-wallets.ts
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_KEY=
# PEM-encoded SPKI public verification key for Privy auth tokens (ES256).
# REQUIRED — all auth helpers and middleware fail closed if missing.
# Find it in the Privy dashboard → Settings → Authentication → "Verification key".
# Paste as a single line with literal \n between header/body/footer, e.g.
#   PRIVY_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----\nMFkw...\n-----END PUBLIC KEY-----
PRIVY_VERIFICATION_KEY=
# HMAC salt used to correlate invite attempts by IP without storing raw IPs.
# Any random 32+ char string.
INVITE_IP_SALT=
PRIVY_SOLANA_AGENT_WALLET_ID=
PRIVY_SOLANA_AGENT_WALLET_ADDRESS=
PRIVY_SOLANA_POLICY_ID=
PRIVY_TEMPO_AGENT_WALLET_ID=
PRIVY_TEMPO_AGENT_WALLET_ADDRESS=
PRIVY_TEMPO_POLICY_ID=

# Remlo escrow Anchor program — deployed devnet program ID
# After running anchor build + anchor deploy in ./solana/, paste the program ID here
# AND into solana/Anchor.toml ([programs.devnet]) AND into declare_id!() in
# solana/programs/remlo-escrow/src/lib.rs. All three must match.
# Then run pnpm tsx scripts/update-privy-solana-policy.ts to whitelist the
# program ID in the Solana server wallet's policy.
REMLO_ESCROW_PROGRAM_ID=

# Cron secret for /api/cron/process-expired-escrows (any 32-byte hex string)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Deterministic seed for the 24-employee demo seeder (scripts/seed-24-employees.ts)
SEED_PHRASE_EMPLOYEES=

# ─── Ship 3: cross-chain reputation ─────────────────────────────────────────
# SAS (Solana Attestation Service) — Solana-side recipient reputation.
# Populate by running: pnpm tsx scripts/setup-sas-schemas.ts
SAS_CREDENTIAL_AUTHORITY=
SAS_SCHEMA_PAYMENT_COMPLETED=
SAS_SCHEMA_ESCROW_SETTLED=
SAS_SCHEMA_ESCROW_REFUNDED=
SAS_SCHEMA_EMPLOYER_VERIFIED=

# ERC-8004 — Tempo-side agent-to-agent reputation.
# Populate by running the Foundry deploy:
#   cd contracts && forge install OpenZeppelin/openzeppelin-contracts-upgradeable@v5.4.0 OpenZeppelin/openzeppelin-contracts@v5.4.0
#   forge script script/DeployERC8004.s.sol --rpc-url tempo_moderato --broadcast
# Required at deploy time:
#   REMLO_PAYROLL_AGENT_ADDRESS     — declared service principal
#   REMLO_VALIDATOR_AGENT_ADDRESS   — declared validator principal
#   REMLO_AGENT_BASE_URI            — https://remlo.xyz/.well-known/agent-registration
NEXT_PUBLIC_ERC8004_IDENTITY_REGISTRY=
NEXT_PUBLIC_ERC8004_REPUTATION_REGISTRY=
NEXT_PUBLIC_ERC8004_VALIDATION_REGISTRY=
REMLO_PAYROLL_AGENT_ID=
REMLO_VALIDATOR_AGENT_ID=
# Client-side mirrors for the dashboard reputation page
NEXT_PUBLIC_REMLO_PAYROLL_AGENT_ID=
NEXT_PUBLIC_REMLO_VALIDATOR_AGENT_ID=
